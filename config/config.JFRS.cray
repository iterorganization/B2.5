# Test whether necessary variables are set
MDSPLUS_DIR ?= /opt/mdsplus/7.96.12
LD_MSCL     ?= -L${SOLPSLIB} -lmscl
LD_NETCDF   ?= $(shell pkg-config netcdf-fortran --libs)
ifdef NCARG_ROOT
LD_NCARG    ?= $(shell pkg-config ncarg --libs)
endif
ifdef SOLPS_MPI
ifdef SOLPS_OPENMP
LD_NAG      ?= $(shell pkg-config sci_mpi_mp --libs)
else
LD_NAG      ?= $(shell pkg-config sci_mpi --libs)
endif
else
ifdef SOLPS_OPENMP
LD_NAG      ?= $(shell pkg-config sci_mp --libs)
else
LD_NAG      ?= $(shell pkg-config sci --libs)
endif
endif

EQUIVS = -Dsgbtrf=dgbtrf -Dsgbtrs=dgbtrs -Dsgetri=dgetri -Dsgetrf=dgetrf

DEFINES += -DNO_OPT
ifndef SOLPS_CPP
  DEFINES += -DCRAY
  ifeq ($(shell `pkg-config --exists fundamental-constants`; echo $$?),0)
    CONSTANTS_MINOR_VERSION = $(shell pkg-config fundamental-constants --modversion | cut -d '.' -f 2)
    DEFINES += -DCONSTANTS_PROVIDED  -DCONSTANTS_MINOR_VERSION=${CONSTANTS_MINOR_VERSION}
    SOLPSINCLUDE += $(shell pkg-config fundamental-constants --cflags)
    IMAS_PKG_LIST = fundamental-constants
  endif
endif

ifdef IMAS_PKG_LIST
  INCMODS += $(shell pkg-config ${IMAS_PKG_LIST} --cflags)
endif

ifdef SOLPS_MPI
  DPFINES += -DMPI_VERSION=${MPI_VERSION} -DMPI_MOD=${MPI_MOD}
endif

FC = ftn
FN = ${FC}
CPP = /lib/cpp -traditional
CPPOPTS = -P -I${srcdir} ${EQUIVS}

COMPILER_MAJOR_VERSION = $(shell ${FC} -V 2>&1 | grep -o "Version [0-9]*" | cut -d ' ' -f 2 )

FCOPTS = -e0 -ez
ifdef SOLPS_DEBUG
  FCOPTS += -O0 -hfp0 -g -G0 -K trap=divz -K trap=fp -Rb
else
  FCOPTS += -O2 -hfp2
endif
ifdef SOLPS_OPENMP
  ifeq ($(shell test ${COMPILER_MAJOR_VERSION} -ge 9; echo $$?),0)
    FPOPTS += -homp
  endif
else
  FCOPTS += -hnoomp
endif
OBJDEST = -J${OBJDIR}
OBNDEST = -J${OBNDIR}
INCMOD = -p
INCMODS += -ef -em
MOD = mod

BLD = ar rucv

GRLIBES = ${LD_NCARG}
PLLIBES = ${LD_MSCL}
LDLIBES = ${LD_NETCDF}

LD = ${FC}
LN = ${FN}
LDOPTS = -dynamic -hpic
# JFRS OPENMP
ifdef SOLPS_OPENMP
  ifeq ($(shell test ${COMPILER_MAJOR_VERSION} -ge 9; echo $$?),0)
    LPOPTS += -homp
  endif
endif


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:
