# Test whether necessary variables are set
#MDSPLUS_DIR ?= ${SOLPSTOP}/../MDSPLUS
#NCDIR       ?= ${SOLPSTOP}/../NETCDF
#MSCL_ROOT   ?= ${SOLPSTOP}/../mscl
#NCARG_ROOT  ?= ${SOLPSTOP}/../NCARG
#NAGDIR      ?= ${SOLPSTOP}/../nag
#LD_NETCDF   ?= -L${NCDIR}/lib -lnetcdf
#LD_MSCL     ?= -L${MSCL_ROOT}/lib -lmscl
#LD_NCARG    ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib64 -lX11 -lm
#LD_NAG      ?= -L${NAGDIR} -lnag

CPP      = /lib/cpp -traditional

ifdef USE_MPI
FC       = mpif90
FC       = mpiifort
else
ifdef USE_IMPGYRO
FC       = mpif90
FC       = mpiifort
else
FC       = ifort
endif
endif

COMPILER_MAJOR_VERSION = $(shell ${FC} -V 2>&1 | grep -o "Version [0-9]*" | cut -d ' ' -f 2 )

ifdef SOLPS_DEBUG
FCOPTS   = -g -C -traceback
ifdef USE_MPI
FCOPTS  += -fpe0
else
FCOPTS  += -debug all -fPIC -assume no2underscore
ifdef USE_IMPGYRO
FCOPTS  += ${MPI_CPP}
else
FCOPTS  += -check all -fpe0
endif
endif
else
FCOPTS   = -O2 -xHost -fPIC -assume no2underscore
ifeq ($(shell test ${COMPILER_MAJOR_VERSION} -ge 15; echo $$?),0)
FCOPTS  += -fp-model=precise
endif
ifdef USE_MPI
FCOPTS  += ${MPI_CPP}
else
ifdef USE_IMPGYRO
FCOPTS  += ${MPI_CPP}
endif
endif
endif

ifdef USE_OPENMP
ifeq ($(shell test ${COMPILER_MAJOR_VERSION} -ge 15; echo $$?),0)
FCOPTS  += -qopenmp
LDOPTS  += -qopenmp
else
FCOPTS  += -openmp
LDOPTS  += -openmp
endif
endif

ifeq ($(shell test ${COMPILER_MAJOR_VERSION} -le 12; echo $$?),0)
FCOPTS  += -vec_report0
LDOPTS  += -i_dynamic
endif

ifdef USE_MPI
LDLIBES += ${LD_MPI}
endif

INCMOD   = -I
OBJDEST  = -module ${OBJDIR} -o ${OBJDIR}/$*.o


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

