# Test whether necessary variables are set

CPP = /lib/cpp -traditional

DDBLOPTION = -Ad # ???

INCMOD = -B
# Test whether necessary variables are set
MDSPLUS_DIR ?= /marconi_work/FUSIO_ALL/SOLPS-ITER/${COMPILER}/MDSPLUS
NCARG_ROOT  ?= /marconi_work/FUSIO_ALL/SOLPS-ITER/${COMPILER}/NCARG
MSCL_ROOT   ?= /marconi_work/FUSIO_ALL/SOLPS-ITER/${COMPILER}/mscl/1.2.3
GLI_HOME    ?= /marconi_work/FUSIO_ALL/SOLPS-ITER/${COMPILER}/gks
NAGDIR      ?= /marconi_work/FUSIO_ALL/SOLPS-ITER/${COMPILER}/nag
NCDIR       ?= ${NETCDFF_HOME}
MPDIR       ?= ${INTELMPI_HOME}

LD_MDSPLUS ?= -L${MDSPLUS_DIR}/lib -lMdsLib_client
LD_NETCDF  ?= -L${NCDIR}/lib -lnetcdff
LD_NCARG   ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib64 -lX11 -lm
LD_MSCL    ?= -L${MSCL_ROOT}/lib -lmscl
LD_NAG     ?= -L${NAGDIR} -lnag -lstdc++
LD_MPI     ?= -L${MPDIR}/lib64 -lmpi -lmpigf

DEFINES += -DNO_OPT

CPP = /lib/cpp -traditional

ifdef USE_MPI
FC = mpif90
else
FC = gfortran
endif

GFORTRAN_VERSION ?= $(shell ${FC} --version | head -1 | awk 'match($$0,/[0-9]+\.[0-9]+\.[0-9]+/){print substr($$0, RSTART, RLENGTH)}')

GFORTRAN_MAJOR_VERSION ?= $(shell echo ${GFORTRAN_VERSION} | cut -d '.' -f 1 )
GFORTRAN_MINOR_VERSION ?= $(shell echo ${GFORTRAN_VERSION} | cut -d '.' -f 2 )

DDBLOPTION = -Ad # ???

ifndef SOLPS_CPP
DEFINES += -DNCAR4 -DNO_F01AAF -DNAG22
endif

ifdef IMAS_VERSION
  ifeq ($(shell `pkg-config --exists ggd`; echo $$?),0)
    GGD_VERSION ?= `pkg-config ggd --modversion`
  else
    GGD_VERSION ?= '0.0.0'
  endif
  LD_UAL += -lstdc++
else
  UAL_MAJOR_VERSION = 0
  UAL_MINOR_VERSION = 0
  UAL_MICRO_VERSION = 0
  IMAS_MAJOR_VERSION = 0
  IMAS_MINOR_VERSION = 0
  IMAS_MICRO_VERSION = 0
  ifdef ITM_ENVIRONMENT_LOADED
    INCMODS += -I${ITM_ITMTYPES_DIR}/${ITM_ITMTYPES_VERSION}/include/amd64_gfortran_6.1 -I${ITM_GGD_HOME}/include/amd64_gfortran_6.1 -I${UAL_INCLUDE}/amd64_gfortran -I${ITM_ITMCONSTANTS_DIR}/include/amd64_gfortran_6.1 -I${ITM_ITMASSERT_DIR}/${ITM_ITMTYPES_VERSION}/include/amd64_gfortran_6.1
    IMASLIBS = ${LD_UAL} -lUALFORTRANInterface_gfortran
  endif
endif

ifdef USE_MPI
LDLIBES += ${LD_MPI}
endif

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

