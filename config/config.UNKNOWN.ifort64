# Test whether necessary variables are set
MDSPLUS_DIR ?= ${SOLPSLIB}
NCDIR       ?= ${SOLPSLIB}
MSCL_ROOT   ?= ${SOLPSLIB}
NCARG_ROOT  ?= ${SOLPSLIB}
NAGDIR      ?= ${SOLPSLIB}
LD_NETCDF   ?= -L${NCDIR}/lib -lnetcdf -lnetcdff
LD_MSCL     ?= -L${MSCL_ROOT}/lib -lmscl
LD_NCARG    ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib64 -lX11 -lm
LD_NAG      ?= -L${NAGDIR}/lib -lnag

CPP      = /lib/cpp -C -traditional -ffreestanding

MPI_FC  ?= mpif90
ifdef SOLPS_MPI
 FC       = ${MPI_FC}
 COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
 ifeq (${COMPILER_TYPE},GNU)
  COMPILER_REDEF = yes
 endif
else
 ifdef USE_IMPGYRO
  FC       = ${MPI_FC}
  COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
  ifeq (${COMPILER_TYPE},GNU)
   COMPILER_REDEF = yes
  endif
 endif
endif

ifndef COMPILER_REDEF
 ifdef SOLPS_DEBUG
  FCOPTS   = -g -C -debug all -traceback -check all
 else
  FCOPTS   = -O2 -xHost
 endif
endif


