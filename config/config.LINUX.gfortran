# Test whether necessary variables are set
LD_NETCDF  = -L${NETCDF_LIB_DIR} -lnetcdf -L${NETCDF_FORTRAN_LIB_DIR} -lnetcdff -lcurl -L${LIBJSON} -ljsonfortran
MSCL_ROOT ?= ${MSCL_HOME}
LD_NCARG   = -L${NCARG_LIB_DIR} -lncarg -lncarg_gks -lncarg_c -lX11 -lXext `pkg-config cairo --libs` -lfontconfig -lz -lXrender -lbz2 -ldl -L${FREETYPE_LIB_DIR} -lfreetype -L${LIBPNG_LIB_DIR} -lpng
LD_NAG     = -L${LAPACK_LIB_DIR} -llapack -L${BLAS_LIB_DIR} -lblas

CPP = /usr/bin/cpp -traditional

GFORTRAN_VERSION ?= $(shell ${FC} --version | head -1 | awk 'match($$0,/[0-9]+\.[0-9]+\.[0-9]+/){print substr($$0, RSTART, RLENGTH)}')

GFORTRAN_MAJOR_VERSION ?= $(shell echo ${GFORTRAN_VERSION} | cut -d '.' -f 1 )
GFORTRAN_MINOR_VERSION ?= $(shell echo ${GFORTRAN_VERSION} | cut -d '.' -f 2 )

ifdef SOLPS_MPI
FC = /usr/bin/mpif90
else
ifdef USE_IMPGYRO
FC = /usr/bin/mpif90
else
FC = gfortran
endif
endif

ifdef SOLPS_OPENMP
FPOPTS  += -fopenmp
LPOPTS  += -fopenmp
endif

DDBLOPTION = -Ad # ???

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

