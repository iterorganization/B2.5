# Test whether necessary variables are set
ifndef LD_NETCDF
  $(error LD_NETCDF not defined)
endif
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif
ifndef LD_NCARG
  $(error LD_NCARG not defined)
endif
ifndef LD_NAG
  $(error LD_NAG not defined)
endif

CPP      = /lib/cpp -C -traditional

MPI_FC  ?= mpif90
ifdef USE_MPI
 FC       = ${MPI_FC}
 COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
 ifeq (${COMPILER_TYPE},GNU)
  COMPILER_REDEF = yes
 endif
else
 ifdef USE_IMPGYRO
  FC       = ${MPI_FC}
  COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
  ifeq (${COMPILER_TYPE},GNU)
   COMPILER_REDEF = yes
  endif
 endif
endif

ifdef COMPILER_REDEF
 ifdef SOLPS_DEBUG
  FCOPTS  += -g -fbounds-check -fbacktrace -ffpe-trap=denormal -ffpe-trap=invalid -ffpe-trap=zero -ftrapv
 else
  FCOPTS  += -O2
 endif
else
# OpenMP compiler options for intel: -openmp is enough
# Might also want -parallel to auto-parallelize loops without openmp directives
 ifndef SOLPS_DEBUG
  FCOPTS  += -O2 -xHost
 else
  FCOPTS  += -g -C -traceback -debug all -check all
 endif
 ifdef USE_MPI
  FCOPTS  += ${MPI_CPP}
  LDOPTS  += ${LD_MPI}
 endif
endif


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

