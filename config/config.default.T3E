# Test whether necessary variables are set
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif
ifndef LD_NCARG
  $(error LD_NCARG not defined)
endif
ifndef LD_NAG
  $(error LD_NAG not defined)
endif
ifndef LD_NETCDF
  $(error LD_NETCDF not defined)
endif

EQUIVS = -Dx02ajf=x02aje -Dx02amf=x02ame -Dx05aaf=x05aae -Dx05abf=x05abe -Df07adf=f07ade -Df06qff=f06qfe -Dd07ajf=d07aje -Dx05baf=x05bae -Dsamax=damax
DEFINES += -DUSE_PXFGETENV -DNO_CDF

ifndef SOLPS_CPP
  ifeq ($(shell `pkg-config --exists fundamental-constants`; echo $$?),0)
    DEFINES += -DCONSTANTS_PROVIDED
    SOLPSINCLUDE += `pkg-config fundamental-constants --cflags`
    IMAS_PKG_LIST = fundamental_constants
  endif
endif

ifdef IMAS_PKG_LIST
  INCMODS += `pkg-config ${IMAS_PKG_LIST} --cflags`
endif

ifdef USE_MPI
DEFINES += -DMPI_VERSION=${MPI_VERSION} -DMPI_MOD=${MPI_MOD}
endif

CPP = /opt/ctl/cf90/cf90/lib/ftpp -F
CPP = /usr/lib/make/cpp
CPPOPTS = -C -P -N -I$(srcdir) $(EQUIVS)
SED = sed s:\#PREC\#:d:g

FC = f90
ifdef SOLPS_DEBUG
FCOPTS = -v -g -dp
else
FCOPTS = -O3 -v -Ounroll2 -eA -X1 -dp
FCOPTS = -O3 -v -Ounroll2 -dp
endif
INCMOD = -p
MOD = o

BLD = ar rucv

GRLIBES = $(LD_NCARG)
PLLIBES = $(LD_MSCL)
LDLIBES = $(LD_NAG)

ifdef LD_CATALYST
CXXFLAGS = -std=c++11
endif

LD = f90 -lapp
LD = f90

LDOPTS = -l /usr/local/pat/libpat.a /usr/local/pat/pat.cld
LDOPTS = 

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

