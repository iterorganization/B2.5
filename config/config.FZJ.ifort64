# Test whether necessary variables are set
NCDIR       ?= /home/s.wiesen/solps-lib/NETCDF
MSCL_ROOT   ?= /home/s.wiesen/solps-lib/mscl
NCARG_ROOT  ?= /home/s.wiesen/solps-lib/NCARG
NAGDIR      ?= /home/s.wiesen/solps-lib/nag
MDSPLUS_DIR ?= /home/s.wiesen/solps-lib/MDSPLUS
LD_NETCDF   ?= -L${NCDIR}/lib -lnetcdf -lnetcdff -I${NCDIR}/include
LD_MSCL     ?= -L${MSCL_ROOT} -lmscl
LD_NCARG    ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -lX11 -lm
LD_NAG      ?= -L${NAGDIR} -lnag

CPP      = /lib/cpp -C -traditional -ffreestanding

MPI_FC  ?= mpif90
ifdef SOLPS_MPI
 FC       = ${MPI_FC}
 COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
 ifeq (${COMPILER_TYPE},GNU)
  COMPILER_REDEF = yes
 endif
else
 ifdef USE_IMPGYRO
  FC       = ${MPI_FC}
  COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
  ifeq (${COMPILER_TYPE},GNU)
   COMPILER_REDEF = yes
  endif
 endif
endif

ifdef COMPILER_REDEF
 ifdef SOLPS_DEBUG
  FCOPTS += -g -fbounds-check -fbacktrace -ffpe-trap=denormal -ffpe-trap=invalid -ffpe-trap=zero -ftrapv
 else
  FCOPTS += -O2
 endif
else
 ifdef SOLPS_DEBUG
  FCOPTS   = -g -C -debug all -traceback -check all
 else
  FCOPTS   = -O2 -xHost
 endif
endif


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

