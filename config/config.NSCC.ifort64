# Test whether necessary variables are set
ifndef NCDIR
  $(error NCDIR not defined)
endif
ifndef NAGDIR
  $(error NAGDIR not defined)
endif
LD_NETCDF ?= `nc-config --libs` -lnetcdff
ifdef NCARG_ROOT
LD_NCARG  ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -lX11 -lm
ifndef MSCL_ROOT
  $(error MSCL_ROOT not defined)
endif
LD_MSCL   ?= -L{MSCL_ROOT} -lmscl
endif
LD_NAG    ?= -L${NAGDIR} -lnag

CPP      = /lib/cpp -traditional

#MPI_FC ?= mpiifort
MPI_FC  ?= mpif90
ifdef USE_MPI
 FC       = ${MPI_FC}
 COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
 ifeq (${COMPILER_TYPE},GNU)
  COMPILER_REDEF = yes
 endif
else
 ifdef USE_IMPGYRO
  FC       = ${MPI_FC}
  COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
  ifeq (${COMPILER_TYPE},GNU)
   COMPILER_REDEF = yes
  endif
 endif
endif

ifdef COMPILER_REDEF
 FCOPTS  += ${MPI_CPP}
 LDOPTS  += ${LD_MPI}
else
 ifdef SOLPS_DEBUG
  FCOPTS   = -g -C -debug all -traceback -check all
 else
  FCOPTS   = -O2 -xHost
 endif
endif


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

