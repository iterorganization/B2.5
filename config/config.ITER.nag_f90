# Test whether necessary variables are set
LD_MSCL   ?= `pkg-config mscl --libs`
ifdef NCARG_ROOT
LD_NCARG  ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -lX11 -lXext `pkg-config cairo --libs` -lfontconfig -lfreetype -lpng -lXrender -lbz2 -lz # for NCARG v6.x.x
endif
LD_NAG    ?= -L${NAGDIR}/lib -lnag_nag
LD_NETCDF ?=

EQUIVS = -Dsdot=ddot -Dsasum=dasum -Dsaxpy=daxpy -Dsscal=dscal -Dscopy=dcopy -Dsgbtrf=dgbtrf -Dsgbtrs=dgbtrs -Dsgetri=dgetri -Dsgetrf=dgetrf
ifndef SOLPS_CPP
DEFINES += -DNAGFOR -DNO_CDF -DNO_F01AAF
endif

ifdef USE_MPI
DEFINES += -DMPI_VERSION=${MPI_VERSION} -DMPI_MOD=${MPI_MOD}
endif

CPP = /lib/cpp -C -traditional -ffreestanding
CPPOPTS = -P -I${srcdir} ${EQUIVS}
SED = sed s:\#PREC\#:d:g

FC = nagfor

FCOPTS = -O -x77 -PIC -compatible # -mismatch
INCMOD = -I
MOD = mod
OBJDEST = -mdir ${OBJDIR} -o ${OBJDIR}/$*.o

ifdef USE_OPENMP
FCOPTS += -openmp
LDOPTS += -openmp
endif

BLD = ar rucv

GRLIBES = ${LD_NCARG} ${LD_MSCL}
LDLIBES = ${LD_NAG} ${LD_NETCDF}

ifdef USE_MPI
INCLUDE += -I${EBROOTOPENMPI}/include
INCMODS += -I${EBROOTOPENMPI}/include
endif

ifdef LD_CATALYST
CXXFLAGS = -std=c++11 $(shell paraview-config --include)
endif

LD = nagfor
LDOPTS =
DBLFC = ${FC}
DBLOPTS = -r8
DBLSED = sed -e s:\#PREC\#:d:g

# LDEXTRA  = env.o

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

