# Test whether necessary variables are set
IRISLIB     ?= /fusion/projects/codes/solps/SOLPS-ITER/public_lib/GA.ifort64
MSCL_ROOT   ?= ${IRISLIB}
NCARG_ROOT  ?= ${IRISLIB}/NCARG
NAGDIR      ?= ${IRISLIB}
NCDIR       ?= ${NETCDF_DIR}
MDSPLUS_DIR ?= ${IRISLIB}/mdsplus
LD_NAG      ?= -L${NAGDIR} -lnag
LD_MSCL     ?= -L${MSCL_ROOT} -lmscl
LD_NCARG    ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -L/usr/lib64 -lX11 -lm
LD_NETCDF   ?= -L${NCDIR}/lib -lnetcdff
GLI_HOME    ?= ${IRISLIB}/gli/src

CPP      = /lib/cpp -traditional

ifdef USE_MPI
FC       = mpif90
else
ifdef USE_IMPGYRO
FC       = mpif90
else
FC       = ifort
endif
endif

OBJDEST  = -module ${OBJDIR} -o ${OBJDIR}/$*.o
INCMOD   = -I
COMPILER_MAJOR_VERSION = $(shell ${FC} -V 2>&1 | grep -o "Version [0-9]*" | cut -d ' ' -f 2 )
ifdef SOLPS_DEBUG
FCOPTS   = -g -C -debug all -traceback -check all
else
FCOPTS   = -O2
endif
ifdef USE_OPENMP
FCOPTS  += -qopenmp
LDOPTS  += -qopenmp
endif


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

