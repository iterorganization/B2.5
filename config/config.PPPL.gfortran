# Test whether necessary variables are set
MSCL_ROOT ?= /u/eemdee/linux_gfortran/lib
NCDIR     ?= /usr/pppl/gcc/9.3-pkgs/netcdf-fortran-4.5.2
LD_MSCL   ?= -L${MSCL_ROOT} -lmscl
LD_NCARG  ?= -L/usr/pppl/gcc/9.3-pkgs/ncl-6.6.2/lib/ -lncarg -lncarg_gks -lncarg_c -lX11 -lm -lgcc_s -lfreetype -lcairo -L/usr/pppl/gcc/9.3.0/lib/../lib64 -lgfortran
GLI_HOME  ?= /u/eemdee/linux_gfortran
LD_NAG    ?= -L/usr/pppl/gcc/9.3-pkgs/lapack-3.9.0/lib64 -lXm -llapack -lblas
LD_NETCDF ?= -L${NCDIR}/lib -lnetcdff

ifndef SOLPS_CPP
DEFINES   += -DNCAR4 -DNO_F01AAF -DNO_NAG
endif

CPP = /lib/cpp -traditional

ifdef USE_MPI
FC = mpif90
else
ifdef USE_IMPGYRO
FC = mpif90
else
FC = gfortran
endif
endif

GFORTRAN_VERSION ?= $(shell ${FC} --version | head -1 | awk 'match($$0,/[0-9]+\.[0-9]+\.[0-9]+/){print substr($$0, RSTART, RLENGTH)}')

GFORTRAN_MAJOR_VERSION ?= $(shell echo ${GFORTRAN_VERSION} | cut -d '.' -f 1 )
GFORTRAN_MINOR_VERSION ?= $(shell echo ${GFORTRAN_VERSION} | cut -d '.' -f 2 )

ifdef SOLPS_DEBUG
FCOPTS = -g -frange-check -fbounds-check -Wcharacter-truncation -fcheck=all -fbacktrace -ffpe-trap=denormal -ffpe-trap=invalid -ffpe-trap=zero -ftrapv \
-Waliasing -Wampersand -Wconversion -Wsurprising -Wc-binding-type -Wintrinsics-std -Wintrinsic-shadow -Wline-truncation -Wtarget-lifetime -Winteger-division -Wreal-q-constant #-Wall
#FCOPTS = -Mbackslash -C -g -Mchkfpstk -Mchkptr -Mchkstk -Mpgicoff -tp=k8
endif

DBLOPTION =

ifdef SOLPS_DEBUG
LDOPTS = -g -C
endif

ifeq ($(shell `pkg-config --exists ggd`; echo $$?),0)
GGD_VERSION ?= `pkg-config ggd --modversion`
else
GGD_VERSION ?= '0.0.0'
endif


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

