# Test whether necessary variables are set
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif
ifndef LD_NCARG
  $(error LD_NCARG not defined)
endif
ifndef LD_NAG
  $(error LD_NAG not defined)
endif
ifndef LD_NETCDF
  $(error LD_NETCDF not defined)
endif

EQUIVS = -Dsgbtrf=dgbtrf -Dsgbtrs=dgbtrs -Dsgetri=dgetri -Dsgetrf=dgetrf
ifdef SOLPS_OPENMP
  DPFINES += -D_OPENMP
endif

ifndef SOLPS_CPP
  ifeq ($(shell `pkg-config --exists fundamental-constants`; echo $$?),0)
    CONSTANTS_MINOR_VERSION = $(shell pkg-config fundamental-constants --modversion | cut -d '.' -f 2)
    DEFINES += -DCONSTANTS_PROVIDED  -DCONSTANTS_MINOR_VERSION=${CONSTANTS_MINOR_VERSION}
    SOLPSINCLUDE += $(shell pkg-config fundamental-constants --cflags)
    IMAS_PKG_LIST = fundamental-constants
  endif
endif

ifdef IMAS_PKG_LIST
  INCMODS += $(shell pkg-config ${IMAS_PKG_LIST} --cflags)
endif

ifdef SOLPS_MPI
  DPFINES += -DMPI_VERSION=${MPI_VERSION} -DMPI_MOD=${MPI_MOD}
endif

CPP = cpp -C -traditional
CPPOPTS = -P -I${srcdir} ${EQUIVS}
SED = sed s:\#PREC\#:d:g
SED =
LINK_MOD =

FC = ftn
FN = ${FC}

ifdef SOLPS_DEBUG
  FCOPTS = -g -C
  LDOPTS = -g -C
else
  FCOPTS = -O3
  LDOPTS =
endif

ifdef SOLPS_OPENMP
  FPOPTS += -mp=nonuma
  LPOPTS += -mp=nonuma
endif

DBLFC=${FC}
DDBLOPTION=
DBLSED = sed -e s:\#PREC\#:d:g
DBLSED =

# -I is used to specify search path for modules
INCMOD = -I
MOD = mod
OBJDEST = -o ${OBJDIR}/$*.o
OBNDEST = -o ${OBNDIR}/$*.o

BLD = ar rucv

GRLIBES = ${LD_NCARG} -lcgm -lngmath
PLLIBES = ${LD_MSCL}
LDLIBES = ${LD_NAG} ${LD_NETCDF}

ifdef LD_CATALYST
  CXXFLAGS = -std=c++11
endif

ifdef USE_EIRENE
  LDLIBESEXTRA = ${OBJDIR}/libeirene.a ${OBJDIR}/grlib.o
endif

LD = $(FC)
LN = ${FN}


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

