# Test whether necessary variables are set
ifndef LD_NCARG
  $(error LD_NCARG not defined)
endif
ifndef LD_NAG
  $(error LD_NAG not defined)
endif
ifndef LD_NETCDF
  $(error LD_NETCDF not defined)
endif

DEFINES += -DNO_IEEE

CPP = /lib/cpp -C -traditional -ffreestanding
SED = sed s:\#PREC\#:d:g

FCOPTS   = -Kieee
LDOPTS   = -Kieee -tp px # "-tp px" to fix a compiler bug at JET

DBLOPTION =
DBLSED = sed -e s:\#PREC\#:d:g


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

