# Test whether necessary variables are set
MDSPLUS_DIR ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/MDSPLUS
NCARG_ROOT ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/NCARG
MSCL_ROOT ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/mscl
GLI_HOME ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/gks
NAGDIR ?= ${NAG_HOME}
NCDIR ?= /cineca/prod/opt/libraries/netcdff/4.4.4/intel--pe-xe-2017--binary
MPDIR ?= ${OPENMPI_HOME}

LD_MDSPLUS ?= -L${MDSPLUS_DIR}/lib -lMdsLib_client
LD_NETCDF ?= `pkg-config netcdf-fortran --libs` -Wl,-rpath,/cineca/prod/opt/libraries/netcdff/4.4.4/intel--pe-xe-2017--binary/lib
LD_NCARG ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -lX11 -lm
LD_MSCL ?= -L${MSCL_ROOT}/lib -lmscl
LD_NAG ?= -L${NAG_LIB} -lnag_nag -lnag_mkl -lstdc++
LD_MPI ?= -L${MPDIR}/lib64 -lmpi

DEFINES += -DNO_OPT

CPP = /lib/cpp -traditional

MPI_FC ?= mpifort
ifdef SOLPS_MPI
FC      = ${MPI_FC}
endif

DDBLOPTION = -Ad # ???

ifndef SOLPS_CPP
DEFINES += -DITM -DNO_F01AAF -DNAG22
endif

ifdef IMAS_VERSION
ifeq ($(shell `pkg-config --exists ggd`; echo $$?),0)
GGD_VERSION ?= `pkg-config ggd --modversion`
else
GGD_VERSION ?= '0.0.0'
endif
LD_AL += -lstdc++
else
AL_MAJOR_VERSION = 0
AL_MINOR_VERSION = 0
AL_MICRO_VERSION = 0
IMAS_MAJOR_VERSION = 0
IMAS_MINOR_VERSION = 0
IMAS_MICRO_VERSION = 0
ifdef ITM_ENVIRONMENT_LOADED
INCMODS += -I${ITM_ITMTYPES_DIR}/${ITM_ITMTYPES_VERSION}/include/amd64_gfortran_6.1 -I${ITM_GGD_HOME}/include/amd64_gfortran_6.1 -I${UAL_INCLUDE}/amd64_gfortran -I${ITM_ITMCONSTANTS_DIR}/include/amd64_gfortran_6.1 -I${ITM_ITMASSERT_DIR}/${ITM_ITMTYPES_VERSION}/include/amd64_gfortran_6.1
IMASLIBS = ${LD_AL} -lUALFORTRANInterface_gfortran
endif
endif

ifdef SOLPS_MPI
LDLIBES += ${LD_MPI}
endif

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

