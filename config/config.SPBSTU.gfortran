# Test whether necessary variables are set
#MDSPLUS_DIR ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/MDSPLUS
#NCARG_ROOT ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/NCARG
#MSCL_ROOT ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/mscl
#NAGDIR ?= ${NAG_HOME}
#NCDIR ?= /cineca/prod/opt/libraries/netcdff/4.4.4/intel--pe-xe-2017--binary
#MPDIR ?= ${INTELMPI_HOME}

     NCDIR_C ?= /opt/software/netcdf-c/4.5.0/gcc
     NCDIR_F ?= /opt/software/netcdf-fortran/4.4.4/gcc
       NCDIR ?= ${NCDIR_F}
   MSCL_ROOT ?= ${SOLPSTOP}/../${COMPILER}/mscl
       H5DIR ?= /opt/software/hdf5/1.10.1/gcc
     GR_ROOT ?= ${SOLPSTOP}/../${COMPILER}/gr
    GLI_HOME ?= ${SOLPSTOP}/../${COMPILER}/gks
  NCARG_ROOT ?= ${SOLPSTOP}/../${COMPILER}/NCARG
      NAGDIR ?= ${SOLPSTOP}/../${COMPILER}/nag
 MDSPLUS_DIR ?= ${SOLPSTOP}/../${COMPILER}/MDSPLUS
       MPDIR ?= ${I_MPI_ROOT}



LD_MDSPLUS ?= -L${MDSPLUS_DIR}/lib -lMdsLib_client
LD_NETCDF ?= -L${NCDIR_C}/lib -lnetcdf -L${NCDIR_F}/lib -lnetcdff
LD_NCARG ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib64 -lX11 -lm
LD_MSCL ?= -L${MSCL_ROOT} -lmscl
LD_NAG ?= -L${NAG_LIB} -lnag_nag -lnag_mkl
LD_MPI ?= -L${MPDIR}/lib64 -lmpi -lmpigf

DEFINES += -DNO_OPT

CPP = /lib/cpp -traditional

MPI_FC ?= mpif90
ifdef USE_MPI
FC      = ${MPI_FC}
else
FC     ?= gfortran
endif

GFORTRAN_VERSION ?= $(shell ${FC} --version | head -1 | awk 'match($$0,/[0-9]+\.[0-9]+\.[0-9]+/){print substr($$0, RSTART, RLENGTH)}')

GFORTRAN_MAJOR_VERSION ?= $(shell echo ${GFORTRAN_VERSION} | cut -d '.' -f 1 )
GFORTRAN_MINOR_VERSION ?= $(shell echo ${GFORTRAN_VERSION} | cut -d '.' -f 2 )

DDBLOPTION = -Ad # ???

ifndef SOLPS_CPP
DEFINES += -DITM
endif

ifndef IMAS_VERSION
AL_MAJOR_VERSION = 0
AL_MINOR_VERSION = 0
AL_MICRO_VERSION = 0
GGD_MAJOR_VERSION = 0
GGD_MINOR_VERSION = 0
GGD_MICRO_VERSION = 0
IMAS_MAJOR_VERSION = 0
IMAS_MINOR_VERSION = 0
IMAS_MICRO_VERSION = 0
ifdef ITM_ENVIRONMENT_LOADED
INCMODS += -I${ITM_ITMTYPES_DIR}/${ITM_ITMTYPES_VERSION}/include/amd64_gfortran_6.1 -I${ITM_GGD_HOME}/include/amd64_gfortran_6.1 -I${UAL_INCLUDE}/amd64_gfortran -I${ITM_ITMCONSTANTS_DIR}/include/amd64_gfortran_6.1 -I${ITM_ITMASSERT_DIR}/${ITM_ITMTYPES_VERSION}/include/amd64_gfortran_6.1
IMASLIBS = ${LD_AL} -lUALFORTRANInterface_gfortran
endif
endif

ifdef USE_MPI
LDLIBES += ${LD_MPI}
endif

