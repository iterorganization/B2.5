# Test whether necessary variables are set
MDSPLUS_DIR ?= ${EBROOTMDSPLUS}
NCDIR       ?= ${EBROOTNETCDFMINFORTRAN}
LD_NETCDF   ?= `pkg-config netcdf-fortran --libs`
MSCL_ROOT   ?= /pfs/work/g2dpc/SOLPS-ITER/mscl
LD_MSCL     ?= -L${MSCL_ROOT}/lib -lmscl
NCARG_ROOT  ?= /pfs/work/g2dpc/SOLPS-ITER/NCARG
LD_NCARG    ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -lX11 -lm
GLI_HOME    ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/gks
NAGDIR      ?= ${EBROOTOPENBLAS}
LD_NAG      ?= `pkg-config openblas --libs`

DEFINES += -DNO_OPT # -DNO_CDF

CPP      = /lib/cpp -C -traditional -ffreestanding

MPI_FC  ?= mpiifort
ifdef SOLPS_MPI
FC       = ${MPI_FC}
else
ifdef USE_IMPGYRO
FC       = ${MPI_FC}
endif
endif

FCOPTS   = -fPIC -assume no2underscore
ifdef SOLPS_DEBUG
FCOPTS  += -g -C -debug all -traceback -check all
else
FCOPTS  += -O2 -xHost
endif

ifndef SOLPS_CPP
DEFINES += -DITM -DNO_NAG
endif

ifdef IMAS_VERSION
  ifeq ($(shell `pkg-config --exists ggd`; echo $$?),0)
    GGD_VERSION ?= `pkg-config ggd --modversion`
  else
    GGD_VERSION ?= '0.0.0'
  endif
else
  ifdef ITM_ENVIRONMENT_LOADED
    DEFINES += -DGOT_AMNSPROTO
    INCMODS += -I${ITM_ITMTYPES_DIR}/${ITM_ITMTYPES_VERSION}/include/amd64_intel_17 -I${ITM_GGD_HOME}/include/amd64_intel_17 -I${UAL_INCLUDE}/amd64_ifort -I${ITM_ITMCONSTANTS_DIR}/include/amd64_intel_17 -I${ITM_ITMASSERT_DIR}/0.1/include/amd64_intel_17
    IMASLIBS = ${LD_AL} -lUALFORTRANInterface_ifort
  endif
endif

LD_AL += -lxml2 -lstdc++


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:
