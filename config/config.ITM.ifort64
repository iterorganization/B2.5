# Test whether necessary variables are set
MDSPLUS_DIR ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/MDSPLUS
NCDIR       ?= /cineca/prod/opt/libraries/netcdff/4.4.4/intel--pe-xe-2017--binary
LD_NETCDF   ?= -L${NCDIR}/lib -lnetcdff
MSCL_ROOT   ?= /pfs/work/g2dpc/SOLPS-ITER/mscl
LD_MSCL     ?= -L${MSCL_ROOT}/lib -lmscl
NCARG_ROOT  ?= /pfs/work/g2dpc/SOLPS-ITER/NCARG
LD_NCARG    ?= -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib64 -lX11 -lm
GLI_HOME    ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/gks
NAGDIR      ?= /pfs/work/g2dpc/SOLPS-ITER/nag
LD_NAG      ?= -L${NAGDIR} -lnag

DEFINES += -DNO_OPT # -DNO_CDF

CPP      = /lib/cpp -C -traditional -ffreestanding

ifdef USE_MPI
FC       = mpiifort
else
ifdef USE_IMPGYRO
FC       = mpiifort
else
FC       = ifort
endif
endif

COMPILER_MAJOR_VERSION = $(shell ${FC} -V 2>&1 | grep -o "Version [0-9]*" | cut -d ' ' -f 2 )

FCOPTS   = -fPIC -assume no2underscore
ifdef SOLPS_DEBUG
FCOPTS  += -g -C -debug all -traceback -check all
else
FCOPTS  += -O2 -xHost -fp-model=precise
endif

ifdef USE_OPENMP
ifeq ($(shell test ${COMPILER_MAJOR_VERSION} -ge 15; echo $$?),0)
FCOPTS  += -qopenmp
LDOPTS  += -qopenmp
else
FCOPTS  += -openmp
LDOPTS  += -openmp
endif
endif

ifeq ($(shell test ${COMPILER_MAJOR_VERSION} -le 12; echo $$?),0)
LDOPTS  += -i_dynamic
endif

INCMOD   = -I
OBJDEST  = -module ${OBJDIR} -o ${OBJDIR}/$*.o

ifndef SOLPS_CPP
DEFINES += -DITM
endif

ifdef IMAS_VERSION
  ifeq ($(shell `pkg-config --exists ggd`; echo $$?),0)
    GGD_VERSION ?= `pkg-config ggd --modversion`
  else
    GGD_VERSION ?= '0.0.0'
  endif
else
  ifdef ITM_ENVIRONMENT_LOADED
    DEFINES += -DGOT_AMNSPROTO
    INCMODS += -I${ITM_ITMTYPES_DIR}/${ITM_ITMTYPES_VERSION}/include/amd64_intel_17 -I${ITM_GGD_HOME}/include/amd64_intel_17 -I${UAL_INCLUDE}/amd64_ifort -I${ITM_ITMCONSTANTS_DIR}/include/amd64_intel_17 -I${ITM_ITMASSERT_DIR}/0.1/include/amd64_intel_17
    IMASLIBS = ${LD_UAL} -lUALFORTRANInterface_ifort
  endif
endif

SOLPSINCLUDE += `pkg-config netcdf-fortran --cflags`

LD_UAL += -lxml2 -lstdc++

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:
