# Test whether necessary variables are set
OS        ?= $(shell grep -m1 NAME /etc/os-release | cut -d '"' -f 2 | cut -d ' ' -f 1 )
NODENAME  ?= $(shell echo `hostname`)
LD_MSCL   ?= `pkg-config mscl --libs`
ifdef NCARG_ROOT
#LD_NCARG ?= -L$(NCARG_ROOT)/lib -lncarg -lncarg_gks -lncarg_c -lm -lX11
LD_NCARG  ?= -L$(NCARG_ROOT)/lib -lncarg -lncarg_gks -lncarg_c -lm -lX11 -lXext `pkg-config cairo --libs` -lfontconfig -lfreetype -lpthread -lXrender -lbz2 -lgfortran
GLI_HOME  ?= ${EBROOTGLI}
endif
ifeq ($(shell `pkg-config --exists netcdf-fortran`; echo $$?),0)
NCDIR     ?= ${EBROOTNETCDFMINFORTRAN}
ifeq (,$(findstring CentOS,$(OS)))
LD_NETCDF  = `pkg-config netcdf-fortran --libs`
else
LD_NETCDF ?= `nf-config --flibs`
endif
ifndef SOLPS_CPP
DEFINES   += -DCDF_MOVIE
INCMODS   += `pkg-config netcdf-fortran --cflags`
endif
else
ifndef SOLPS_CPP
DEFINES   += -DNO_CDF
endif
endif
ifdef NAGDIR
LD_NAG    ?= -lnag_nag
ifndef SOLPS_CPP
DEFINES   += -DNAG22 -DNO_F01AAF
endif
else
LD_NAG    ?= `pkg-config openblas --libs`
ifndef SOLPS_CPP
DEFINES   += -DNO_NAG
endif
endif

DEFINES   += -DNO_OPT

CPP        = /lib/cpp -traditional

# Avoid usage of ifx compiler until its issues are fixed
# ifeq (,$(findstring CentOS,$(OS)))
# MPI_FC    ?= mpiifort -fc=mpiifx
# FN         = ifx
# else
# MPI_FC    ?= mpiifort
# endif
ifdef SOLPS_MPI
FC         = ${MPI_FC}
ifndef MPDIR
MPDIR      = ${EBROOTIMPI}
LD_MPI    += -Wl,-rpath,${MPDIR}/lib64
endif
else
ifdef USE_IMPGYRO
FC         = ${MPI_FC}
ifndef MPDIR
MPDIR      = ${EBROOTIMPI}
LD_MPI    += -Wl,-rpath,${MPDIR}/lib64
endif
# else
# ifeq (,$(findstring CentOS,$(OS)))
# FC         = ifx
# endif
endif
endif

FCOPTS     = -assume no2underscore -align commons -fPIC
ifdef SOLPS_DEBUG
FCOPTS    += -g -C -debug all -traceback -check all -fpe0
LDOPTS    += -check all
else
FCOPTS    += -O2
ifeq (,$(findstring CentOS,$(OS)))
FCOPTS    += -xHost
else
FCOPTS    += -march=sandybridge
endif
endif
ifdef SOLPS_MPI
FPOPTS    += ${MPI_CPP}
else
ifdef USE_IMPGYRO
FPOPTS    += ${MPI_CPP}
endif
endif

LDLIBES    = -lz

ifeq ($(shell `pkg-config --exists ggd`; echo $$?),0)
  GGD_VERSION ?= `pkg-config ggd --modversion`
else
  GGD_VERSION ?= '0.0.0'
endif

ifdef SOLPS_MPI
LDLIBES   += ${LD_MPI}
else
ifdef USE_IMPGYRO
LDLIBES   += ${LD_MPI}
endif
endif


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:
