#LDLIBESEXTRA = ${OBJECTCODE}/libeirene.a ${OBJECTCODE}/grlib.o -lnag
#endif
ifdef PERFMON
LDLIBES += -L${SOLPSLIB} -lperf
endif

ifdef IMAS_PREFIX
INCMODS   += -I${IMAS_PREFIX}/include/ifort
LDLIBES   += ${LD_UAL}
endif

ifdef LD_CATALYST
CXXFLAGS = $(shell paraview-config --include)
endif


LD       = ${FC}
LDOPTS   = 

LCPP     = ${LD_SONNET}


