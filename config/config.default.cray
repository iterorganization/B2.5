# Test whether necessary variables are set
ifndef LD_MSCL
  ifndef SOLPS_CPP
    $(error LD_MSCL not defined)
  else
    $(error LD_MSCL not defined. Run the install_dependencies script first.)
  endif
endif
ifndef LD_NCARG
  $(error LD_NCARG not defined)
endif
ifndef LD_NAG
  $(error LD_NAG not defined)
endif
ifndef LD_NETCDF
  $(error LD_NETCDF not defined)
endif

EQUIVS = -Dsgbtrf=dgbtrf -Dsgbtrs=dgbtrs -Dsgetri=dgetri -Dsgetrf=dgetrf

ifndef SOLPS_CPP
  DEFINES += -DCRAY
  ifeq ($(shell `pkg-config --exists fundamental-constants`; echo $$?),0)
    DEFINES += -DCONSTANTS_PROVIDED
    SOLPSINCLUDE += `pkg-config fundamental-constants --cflags`
    IMAS_PKG_LIST = fundamental-constants
  endif
endif

ifdef IMAS_PKG_LIST
  INCMODS += `pkg-config ${IMAS_PKG_LIST} --cflags`
endif

ifdef SOLPS_MPI
  DPFINES += -DMPI_VERSION=${MPI_VERSION} -DMPI_MOD=${MPI_MOD}
endif

CPP = /lib/cpp -traditional
CPPOPTS = -P -I${srcdir} ${EQUIVS}

FC = ftn
FCOPTS = -e0 -ez
ifdef SOLPS_DEBUG
  FCOPTS += -O0 -hfp0 -g -G0 -K trap=divz -K trap=fp -Rb
else
  FCOPTS += -O2 -hfp2
endif
ifdef SOLPS_OPENMP
  FPOPTS += -homp
endif

OBJDEST = -ef -em -J${OBJDIR}
OBNDEST = -ef -em -J${OBNDIR}
INCMOD = -p
MOD = mod

BLD = ar rucv

GRLIBES =     # graphics libraries
PLLIBES =     # support libraries for plotting programs
LDLIBES =     # other libraries

LD = ${FC}
LN = ${FN}
LDOPTS = -dynamic -hpic


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

